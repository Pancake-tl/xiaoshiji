.moments-card{display:flex;padding:24rpx 36rpx;margin:0;background:#fff;border-bottom:1rpx solid #F0F0F0;cursor:pointer;transition:background .15s}.moments-card:active{background:#F7F7F7}.moments-avatar{width:72rpx;height:72rpx;border-radius:8rpx;background:linear-gradient(135deg,var(--primary),var(--primary-light));display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-right:20rpx}.moments-avatar-text{font-size:32rpx;color:#fff}.moments-body{flex:1;min-width:0}.moments-nickname{font-size:28rpx;font-weight:600;color:var(--primary-dark);margin-bottom:6rpx}.moments-meta{display:flex;flex-wrap:wrap;align-items:center;gap:8rpx;margin-bottom:8rpx}.moments-meta-item{font-size:22rpx;color:var(--text-lighter)}.moments-category{font-size:20rpx;padding:2rpx 12rpx;border-radius:4rpx;background:rgba(0,0,0,0.04)}.moments-content{padding-top:4rpx}.moments-text{font-size:30rpx;line-height:1.7;color:var(--text);white-space:pre-wrap;display:-webkit-box;-webkit-line-clamp:4;-webkit-box-orient:vertical;overflow:hidden}
