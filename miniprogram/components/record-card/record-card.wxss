.rc{position:relative;margin:0 24rpx 20rpx;transition:all .2s;cursor:pointer}.rc:active{transform:scale(0.98)}.tape{position:absolute;top:-10rpx;left:30rpx;width:80rpx;height:24rpx;background:linear-gradient(135deg,rgba(255,200,150,0.7),rgba(255,180,130,0.5));border-radius:2rpx;transform:rotate(-3deg);z-index:2}.rc-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:10rpx}.rc-time{font-size:22rpx;color:var(--text-lighter)}.rc-body{margin-bottom:10rpx}.rc-text{font-size:28rpx;line-height:1.7;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}.rc-img-wrap{position:relative;border-radius:8rpx;overflow:hidden}.rc-img{width:100%;height:260rpx}.rc-voice{margin-top:8rpx}.rc-voice-tag{font-size:20rpx;color:var(--primary);background:rgba(255,143,163,0.1);padding:4rpx 14rpx;border-radius:20rpx}