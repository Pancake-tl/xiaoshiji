<view class="moments-card" data-id="{{record._id}}">
  <view class="moments-avatar">
    <text class="moments-avatar-text">{{avatarEmoji}}</text>
  </view>
  <view class="moments-body">
    <text class="moments-nickname">好运小事</text>
    <view class="moments-meta">
      <text class="moments-meta-item">{{record.recordDate}} {{record.recordTime}}</text>
      <text wx:if="{{record.mood}}" class="moments-meta-item">{{record.mood}}</text>
      <text wx:if="{{record.weather}}" class="moments-meta-item">{{record.weather}}</text>
      <text wx:if="{{category}}" class="moments-category" style="color:{{category.color}}">{{category.name}}</text>
    </view>
    <view wx:if="{{record.content}}" class="moments-content">
      <text class="moments-text">{{record.content}}</text>
    </view>
  </view>
</view>
