.header-header{padding:10rpx 0 20rpx}.date-divider{display:flex;align-items:center;padding:28rpx 36rpx 16rpx;gap:16rpx}.date-line{flex:1;height:1rpx;background:linear-gradient(90deg,transparent,var(--primary-light),transparent)}.date-label{display:flex;flex-direction:column;align-items:center;gap:4rpx}.load-more{display:flex;align-items:center;justify-content:center;padding:32rpx;min-height:60rpx}.loading-spinner{width:32rpx;height:32rpx;border:3rpx solid var(--border);border-top-color:var(--primary);border-radius:50%;animation:spin 0.8s linear infinite}@keyframes spin{to{transform:rotate(360deg)}}