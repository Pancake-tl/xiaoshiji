<view class="page-container" wx:if="{{record}}">
  <view class="top-decoration"></view>

  <!-- 朋友圈头部：头像 + 昵称 -->
  <view class="moments-header">
    <view class="moment-avatar">
      <text class="moment-avatar-text">{{avatarEmoji}}</text>
    </view>
    <view class="moment-header-right">
      <text class="moment-nickname">好运小事</text>
      <view class="moment-tags">
        <text class="moment-tag">{{record.recordDate}} {{record.recordTime}}</text>
        <text wx:if="{{category}}" class="moment-tag moment-category-tag" style="color:{{category.color}};background:{{category.color}}20">{{category.name}}</text>
        <text wx:if="{{record.mood}}" class="moment-tag">{{record.mood}}</text>
        <text wx:if="{{record.weather}}" class="moment-tag">{{record.weather}}</text>
      </view>
    </view>
  </view>

  <!-- 朋友圈正文 -->
  <view wx:if="{{record.content}}" class="moment-content">
    <text class="moment-text">{{record.content}}</text>
  </view>

  <!-- 朋友圈图片九宫格 -->
  <view wx:if="{{record.images&&record.images.length>0}}" class="moment-images {{'grid-col-' + (record.images.length===1?'1':record.images.length<5?'2':'3')}}">
    <view
      wx:for="{{record.images}}" wx:key="*this"
      class="moment-image-item"
      bindtap="onPreviewImage"
      data-index="{{index}}"
    >
      <image src="{{item}}" mode="{{record.images.length===1?'widthFix':'aspectFill'}}" class="moment-image" />
    </view>
  </view>

  <!-- 语音 -->
  <view wx:if="{{record.voicePath}}" class="moment-voice" bindtap="onPlayVoice">
    <text class="moment-voice-icon">🎤</text>
    <text class="moment-voice-text">{{record.voiceDuration||0}}秒语音</text>
  </view>

  <!-- 操作按钮 -->
  <view class="moment-actions">
    <button class="moment-btn" bindtap="onEdit">编辑</button>
    <button class="moment-btn moment-btn-danger" bindtap="onDelete">删除</button>
  </view>

  <!-- 底部留白 -->
  <view style="height:60rpx"></view>
</view>

<view class="flex-center page-container" wx:else>
  <text style="margin-top:300rpx;font-size:30rpx;color:var(--text-light)">加载中..</text>
</view>
