.deco-tag{display:inline-flex;align-items:center;padding:14rpx 22rpx;background:var(--bg-card);border-radius:30rpx;box-shadow:var(--heal-shadow);border:2rpx solid #E0D5D5;font-size:26rpx;transition:all .25s}
.deco-tag-active{border:2rpx solid var(--primary) !important;background:var(--primary) !important;color:#fff !important;box-shadow:0 4rpx 14rpx rgba(255,143,163,0.35) !important}