<view class="page-container">
  <view class="top-decoration"></view>

  <view class="card card-heal" style="margin:20rpx 36rpx;padding:20rpx 28rpx">
    <text>启动的装饰会出现在首页和小卡片上哦</text>
  </view>

  <view style="padding:0 36rpx;display:flex;justify-content:space-between;align-items:center">
    <text style="font-size:30rpx;font-weight:600">内置装饰</text>
    <view style="padding:8rpx 20rpx;border-radius:30rpx;background:var(--primary-light);font-size:24rpx;color:#fff" bindtap="goMaterials">素材库</view>
  </view>

  <view style="display:flex;flex-wrap:wrap;gap:14rpx;padding:14rpx 36rpx">
    <view
      wx:for="{{builtIn}}" wx:key="id"
      style="display:inline-flex;align-items:center;padding:14rpx 22rpx;border-radius:30rpx;font-size:26rpx;transition:all .25s;{{activeIds.indexOf(item.id)>-1?'background:var(--primary);color:#fff;border:2rpx solid var(--primary);box-shadow:0 4rpx 14rpx rgba(255,143,163,0.35)':'background:var(--bg-card);color:var(--text);border:2rpx solid transparent;box-shadow:var(--heal-shadow)'}}"
      bindtap="onToggle"
      data-id="{{item.id}}"
    >
      <text style="font-size:32rpx">{{item.emoji}}</text>
      <text style="font-size:26rpx;margin-left:6rpx">{{item.name}}</text>
    </view>
  </view>

  <view wx:if="{{customMaterials.length>0}}" style="padding:20rpx 36rpx 0">
    <text style="font-size:30rpx;font-weight:600">自定义素材</text>
  </view>

  <view style="display:flex;flex-wrap:wrap;gap:14rpx;padding:14rpx 36rpx">
    <view
      wx:for="{{customMaterials}}" wx:key="id"
      style="display:inline-flex;align-items:center;padding:14rpx 22rpx;border-radius:30rpx;font-size:26rpx;transition:all .25s;{{activeIds.indexOf('custom_'+item.id)>-1?'background:var(--primary);color:#fff;border:2rpx solid var(--primary);box-shadow:0 4rpx 14rpx rgba(255,143,163,0.35)':'background:var(--bg-card);color:var(--text);border:2rpx solid transparent;box-shadow:var(--heal-shadow)'}}"
      bindtap="onToggleCustom"
      data-custom='{{item}}'
    >
      <image style="width:32rpx;height:32rpx;border-radius:6rpx" src="{{item.fileID}}" mode="aspectFill" />
      <text style="font-size:26rpx;margin-left:6rpx">{{item.name}}</text>
    </view>
  </view>
</view>