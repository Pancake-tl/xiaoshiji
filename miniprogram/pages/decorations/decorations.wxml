<view class="page-container">
  <view class="top-decoration"></view>

  <view class="card card-heal" style="margin:20rpx 36rpx;padding:20rpx 28rpx">
    <text>启动的装饰会出现在首页和小卡片上哦</text>
  </view>

  <view style="padding:0 36rpx;display:flex;justify-content:space-between;align-items:center">
    <text style="font-size:30rpx;font-weight:600">内置装饰</text>
    <view style="padding:8rpx 20rpx;border-radius:30rpx;background:var(--primary-light);font-size:24rpx;color:#fff" bindtap="goMaterials">素材库</view>
  </view>

  <block wx:for="{{categories}}" wx:key="key">
    <view style="padding:20rpx 36rpx 0;font-size:28rpx;font-weight:600;color:{{item.gradStart}}">
      <text>{{item.label}}</text>
      <text style="font-size:22rpx;color:var(--text-lighter);font-weight:400;margin-left:10rpx">点击添加飘落装饰</text>
    </view>

    <view style="display:flex;flex-wrap:wrap;gap:14rpx;padding:8rpx 36rpx 4rpx">
      <view
        wx:for="{{item.items}}" wx:key="id"
        style="display:inline-flex;flex-direction:column;align-items:center"
        bindtap="onToggle"
        data-id="{{item.id}}"
      >
        <!-- 方框：选中/未选中 两种行内样式切换 -->
        <view style="{{activeIds.indexOf(item.id)>-1 ?
          'width:80rpx;height:80rpx;border-radius:16rpx;display:flex;align-items:center;justify-content:center;border:3rpx solid #E8728A;background:#FFDFE5;box-sizing:border-box'
          :
          'width:80rpx;height:80rpx;border-radius:16rpx;display:flex;align-items:center;justify-content:center;border:3rpx solid #E0D5D5;background:#FFFFFF;box-sizing:border-box'
        }}">
          <text style="font-size:34rpx;line-height:1;display:block">{{item.emoji}}</text>
        </view>
        <!-- 选中圆点：选中时有，未选中无 -->
        <view wx:if="{{activeIds.indexOf(item.id)>-1}}" style="width:12rpx;height:12rpx;border-radius:50%;background:#E8728A;margin-top:6rpx;flex-shrink:0"></view>
      </view>
    </view>
  </block>

  <view wx:if="{{customMaterials.length>0}}" style="padding:20rpx 36rpx 0">
    <text style="font-size:30rpx;font-weight:600">自定义素材</text>
  </view>

  <view style="display:flex;flex-wrap:wrap;gap:14rpx;padding:14rpx 36rpx">
    <view
      wx:for="{{customMaterials}}" wx:key="id"
      style="display:inline-flex;flex-direction:column;align-items:center"
      bindtap="onToggleCustom"
      data-custom="{{item}}"
    >
      <view style="{{activeIds.indexOf('custom_'+item.id)>-1 ?
        'width:80rpx;height:80rpx;border-radius:16rpx;display:flex;align-items:center;justify-content:center;border:3rpx solid #E8728A;background:#FFDFE5;box-sizing:border-box'
        :
        'width:80rpx;height:80rpx;border-radius:16rpx;display:flex;align-items:center;justify-content:center;border:3rpx solid #E0D5D5;background:#FFFFFF;box-sizing:border-box'
      }}">
        <image style="width:36rpx;height:36rpx;border-radius:6rpx" src="{{item.fileID}}" mode="aspectFill" />
      </view>
      <view wx:if="{{activeIds.indexOf('custom_'+item.id)>-1}}" style="width:12rpx;height:12rpx;border-radius:50%;background:#E8728A;margin-top:6rpx;flex-shrink:0"></view>
    </view>
  </view>
</view>
