.style-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:6rpx;padding:16rpx 6rpx;background:var(--bg-card);border-radius:14rpx;box-shadow:var(--heal-shadow);border:2rpx solid transparent;transition:all .2s}.si-active{border-color:var(--primary)}.tgl{width:84rpx;height:44rpx;border-radius:22rpx;padding:4rpx;transition:all .3s;flex-shrink:0}.tgl-on{background:var(--primary)}.tgl-off{background:#E0D5D5}.tgl-dot{width:36rpx;height:36rpx;border-radius:50%;background:#fff;box-shadow:0 2rpx 4rpx rgba(0,0,0,0.15);transition:all .3s}.tgl-dot-on{transform:translateX(40rpx)}.tgl-dot-off{transform:translateX(0)}.den-item{flex:1;text-align:center;padding:12rpx;border-radius:14rpx;background:var(--bg-card);font-size:24rpx;color:var(--text-light);border:2rpx solid transparent;transition:all .2s}.den-active{border-color:var(--primary);color:var(--primary)}