/* ???? */
.login-btn{background:linear-gradient(135deg,var(--primary),var(--primary-light));color:#fff;font-size:24rpx;border-radius:40rpx;padding:14rpx 28rpx;flex-shrink:0;font-weight:500;box-shadow:0 4rpx 12rpx rgba(255,143,163,0.25);transition:opacity .2s}.login-btn:active{opacity:.8}.login-btn-loading{opacity:.6}
/* ????????????? */
.avatar-wrapper{width:120rpx;height:120rpx;flex-shrink:0;flex:none;overflow:hidden;background:linear-gradient(135deg,var(--cute-pink),var(--cute-lavender));display:flex;align-items:center;justify-content:center;line-height:0}.avatar-wrapper image{width:100%;height:100%;display:block}
/* ??????? */
.avatar-placeholder{width:120rpx;height:120rpx;background:linear-gradient(135deg,var(--cute-pink),var(--cute-lavender));display:flex;align-items:center;justify-content:center;font-size:40rpx;color:#fff;flex-shrink:0;flex:none}
/* ???? */
.nickname-input{font-size:32rpx;font-weight:600;padding:0;min-height:40rpx;background:transparent;border:none;color:var(--text)}
/* ?????? */
.style-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:6rpx;padding:16rpx 6rpx;background:var(--bg-card);border-radius:14rpx;box-shadow:var(--heal-shadow);border:2rpx solid transparent;transition:all .2s}.si-active{border-color:var(--primary)}.tgl{width:84rpx;height:44rpx;border-radius:22rpx;padding:4rpx;transition:all .3s;flex-shrink:0}.tgl-on{background:var(--primary)}.tgl-off{background:#E0D5D5}.tgl-dot{width:36rpx;height:36rpx;border-radius:50%;background:#fff;box-shadow:0 2rpx 4rpx rgba(0,0,0,0.15);transition:all .3s}.tgl-dot-on{transform:translateX(40rpx)}.tgl-dot-off{transform:translateX(0)}.den-item{flex:1;text-align:center;padding:12rpx;border-radius:14rpx;background:var(--bg-card);font-size:24rpx;color:var(--text-light);border:2rpx solid transparent;transition:all .2s}.den-active{border-color:var(--primary);color:var(--primary)}.avatar-initial{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:28rpx;color:#fff;font-weight:500}
